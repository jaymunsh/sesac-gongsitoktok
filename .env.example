# 상대 경로: .env.example
#
# 본 파일은 commit 대상. 실제 값은 .env (gitignore) 에 채워서 사용.
# 신규 팀원/CI 가 본 파일을 .env 로 복사한 뒤 값 채우면 부팅 가능.
#
# 사용 예:
#   cp .env.example .env
#   # IntelliJ Run Config 의 EnvFile 항목에 .env 경로 지정
#   # 또는 CLI: set -a && source .env && set +a && ./gradlew bootRun
#
# 키 13개. 모두 application.yml / application-{dev,prod}.yml 에서 ${...} 로 참조됨.

# ===== Database =====
# dev profile 은 jdbc URL 하드코딩 (localhost:5432/gongsitoktok). 자격증명만 필요.
DB_USERNAME=gongsi
DB_PASSWORD=gongsi
# prod profile 전용. dev 에서는 주석 처리해도 무관.
DB_URL=jdbc:postgresql://localhost:5432/gongsitoktok

# ===== FastAPI AI Agent =====
FASTAPI_BASE_URL=http://localhost:8000

# ===== JWT (Access Token) =====
# 32바이트(256bit) 이상 강제. 운영은 `openssl rand -hex 32` 로 발급.
JWT_SECRET=REPLACE-WITH-AT-LEAST-32-BYTES-RANDOM-SECRET

# ===== CORS · OAuth redirect =====
CORS_ALLOWED_ORIGINS=http://localhost:3000
OAUTH_FRONTEND_REDIRECT_URI=http://localhost:3000/oauth/callback

# ===== OAuth Client =====
# 미사용 시 아래 라인 전부 주석 유지 (application.yml 의 disabled-*-client 기본값이 적용됨).
# 활성화 시 사용할 provider 의 두 라인만 주석 해제 후 실제 값 채움.
# OAUTH_GOOGLE_CLIENT_ID=
# OAUTH_GOOGLE_CLIENT_SECRET=
# OAUTH_KAKAO_CLIENT_ID=
# OAUTH_KAKAO_CLIENT_SECRET=
# OAUTH_NAVER_CLIENT_ID=
# OAUTH_NAVER_CLIENT_SECRET=
